# =============================================================================
# Vertana — copy to .env.local and fill in your values
# =============================================================================
# Supabase: Project Settings → API
# OpenAI: platform.openai.com → API Keys
# =============================================================================

# --- Supabase (required) ---
# Project URL (e.g. https://xxxxx.supabase.co)
SUPABASE_URL=

# anon / public key
SUPABASE_ANON_KEY=

# service_role key — server only, never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=

# Database password (from project creation) — needed only to run `pnpm migrate`
SUPABASE_DB_PASSWORD=

# --- Local dev only (optional) ---
# Initial plan_tier for new orgs created at signup: free | starter | growth | custom
# Defaults to free if unset. Once Stripe/billing is live, plan_tier is set in the
# database at checkout — this has no effect on existing organizations.
VERTANA_PLAN_TIER=free

# --- AI question generation (server-side only) ---
# platform.openai.com → API Keys
OPENAI_API_KEY=
# Optional model override (default: gpt-4.1-mini)
# OPENAI_MODEL=gpt-4.1-mini

# --- Code execution via Judge0 (server-side only) ---
# Sign up at rapidapi.com/judge0-official/api/judge0-ce (free tier: ~500 req/day)
# Or use judge0.com cloud / self-hosted — set JUDGE0_API_URL for non-RapidAPI hosts
JUDGE0_API_KEY=
# RapidAPI hosted (default):
# JUDGE0_RAPIDAPI_HOST=judge0-ce.p.rapidapi.com
# JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com
# Self-hosted Judge0 CE (see lib/execution/judge0.ts):
# JUDGE0_AUTH_MODE=self-hosted
# JUDGE0_API_URL=http://localhost:2358

# --- Completion notifications (optional) ---
# Without RESEND_API_KEY, completion notifications are logged server-side only.
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=Vertana <notifications@yourdomain.com>
# NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# Tab switches at or above this count show an integrity concern badge (default: 3).
# Per-organization override is stored in organizations.tab_switch_threshold (migration 010).
# VERTANA_TAB_SWITCH_THRESHOLD=3
