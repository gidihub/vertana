# =============================================================================
# Vertana — copy to .env.local and fill in your values
# =============================================================================
# Supabase: Project Settings → API
# OpenAI: platform.openai.com → API Keys
# =============================================================================

# --- Supabase (required) ---
# Project URL (e.g. https://xxxxx.supabase.co)
SUPABASE_URL=

# anon / public key
SUPABASE_ANON_KEY=

# service_role key — server only, never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=

# Database password (from project creation) — needed only to run `pnpm migrate`
SUPABASE_DB_PASSWORD=

# --- Local dev only (optional) ---
# Initial plan_tier for new orgs created at signup: free | starter | growth | custom
# Defaults to free if unset. Once Stripe/billing is live, plan_tier is set in the
# database at checkout — this has no effect on existing organizations.
VERTANA_PLAN_TIER=free

# --- AI question generation (server-side only) ---
# platform.openai.com → API Keys
OPENAI_API_KEY=
# Optional model override (default: gpt-5.4-mini)
# OPENAI_MODEL=gpt-5.4-mini

# --- Staff CMS (server-side only) ---
# Comma-separated emails allowed to access /cms and CMS APIs
CMS_STAFF_EMAILS=you@yourdomain.com

# --- Code execution via Judge0 (server-side only) ---
# Sign up at rapidapi.com/judge0-official/api/judge0-ce (free tier: ~500 req/day)
# Or use judge0.com cloud / self-hosted — set JUDGE0_API_URL for non-RapidAPI hosts
JUDGE0_API_KEY=
# RapidAPI hosted (default):
# JUDGE0_RAPIDAPI_HOST=judge0-ce.p.rapidapi.com
# JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com
# Self-hosted Judge0 CE (see lib/execution/judge0.ts):
# JUDGE0_AUTH_MODE=self-hosted
# JUDGE0_API_URL=http://localhost:2358

# --- Transactional email — Brevo (required for sending) ---
# app.brevo.com → SMTP & API → API keys (create a transactional key)
# Verify your sender domain or at least the from-address in Brevo before sending.
# Without BREVO_API_KEY, invite/completion/team emails are logged server-side only.
BREVO_API_KEY=
BREVO_FROM_EMAIL=notifications@yourdomain.com
BREVO_FROM_NAME=Vertana
# Public app URL for links in emails (invites, results, team accept)
# NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# Tab switches at or above this count show an integrity concern badge (default: 3).
# Per-organization override is stored in organizations.tab_switch_threshold (migration 010).
# VERTANA_TAB_SWITCH_THRESHOLD=3

# --- Stripe billing (server-side only) ---
# dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=
# dashboard.stripe.com → Developers → Webhooks → signing secret
# Endpoint URL: https://your-domain/api/billing/webhook
STRIPE_WEBHOOK_SECRET=
# Stripe Price IDs are provisioned automatically by `pnpm setup:stripe`, which
# creates the products/prices/coupon from lib/pricing/config.ts and writes the
# Price IDs into the plans / credit_packs tables (the source checkout reads from).
# The env vars below are only an optional fallback used when a DB column is unset.
# STRIPE_PRICE_STARTER_MONTHLY=
# STRIPE_PRICE_STARTER_ANNUAL=
# STRIPE_PRICE_GROWTH_MONTHLY=
# STRIPE_PRICE_GROWTH_ANNUAL=
# STRIPE_PRICE_PACK_50=
# STRIPE_PRICE_PACK_200=
# STRIPE_PRICE_PACK_500=
# Regional fallbacks use PPP tier suffixes (t2..t5), e.g.
# STRIPE_PRICE_GROWTH_MONTHLY_PPP_T3=

# --- Proctoring (optional — camera snapshot step) ---
# Set both to true to enable identity snapshot after consent on proctored tests.
# PROCTORING_CAMERA_ENABLED=false
# NEXT_PUBLIC_PROCTORING_CAMERA_ENABLED=false
